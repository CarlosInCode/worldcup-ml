# Copia este archivo a .env y rellena tus valores. .env NUNCA se sube a git.

# --- api-football (plan de pago) ---
# Si usas el endpoint DIRECTO de API-Sports:
API_FOOTBALL_KEY=tu_api_key_aqui
API_FOOTBALL_BASE_URL=https://v3.football.api-sports.io
# Si en cambio contrataste vía RapidAPI, usa estos en su lugar:
# API_FOOTBALL_BASE_URL=https://api-football-v1.p.rapidapi.com/v3
# API_FOOTBALL_RAPIDAPI_HOST=api-football-v1.p.rapidapi.com

# Límite de llamadas por minuto de tu plan (ajústalo a tu suscripción).
API_FOOTBALL_RATE_LIMIT_PER_MIN=300

# --- Rutas de datos (medallón) ---
DATA_DIR=./data
